{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "a78cc72dd6444e40bdf5b51ce4c3f4ca",
    "m_Title": "广义洛伦兹函数",
    "m_Content": "广义洛伦兹函数：\ny=(y0 * w^n) / ((|x-x0|)^n + w^n)\n\nx0:波峰位置,这里用Time生成了一个0-1的循环\ny0:波峰高度\nw:波峰宽度\nn:控制波形,2时是标准洛伦兹函数\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1962.0,
        "y": 1028.0,
        "width": 200.0,
        "height": 160.0
    },
    "m_Group": {
        "m_Id": "8bc9b0f20cbd43569914d77be4d66f03"
    }
}

